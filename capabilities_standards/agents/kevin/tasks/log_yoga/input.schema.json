{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "log_yoga.input",
  "type": "object",
  "required": ["yoga_done", "yoga_type"],
  "properties": {
    "yoga_done": {
      "type": "boolean",
      "const": true
    },
    "yoga_type": {
      "type": "string",
      "minLength": 1
    },
    "record_id": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": false
}
