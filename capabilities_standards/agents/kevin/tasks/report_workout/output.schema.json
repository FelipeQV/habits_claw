{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "report_workout.output",
  "type": "object",
  "required": ["protocol_version", "task", "ok", "data", "error", "meta"],
  "properties": {
    "protocol_version": { "const": "1.0.0" },
    "task": { "const": "report_workout" },
    "ok": { "type": "boolean" },
    "data": {
      "type": ["object", "null"],
      "required": ["summary", "totals", "workout_done", "cardio_total_min"],
      "properties": {
        "summary": { "type": "string" },
        "totals": {
          "type": "object",
          "required": ["cardio_minutes", "routine_days"],
          "properties": {
            "cardio_minutes": { "type": "integer" },
            "routine_days": { "type": "integer" }
          }
        },
        "workout_done": { "type": "boolean" },
        "cardio_total_min": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "required": ["timestamp", "trace_id"],
      "properties": {
        "source": { "const": "duckdb" },
        "db_path": { "const": "/home/ubuntu/health_system.duckdb" },
        "agent_id": { "const": "kevin" },
        "timestamp": { "type": "string" },
        "trace_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
