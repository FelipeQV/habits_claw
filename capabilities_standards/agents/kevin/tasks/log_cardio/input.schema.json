{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "log_cardio.input",
  "type": "object",
  "required": ["cardio_type", "minutes"],
  "properties": {
    "cardio_type": {
      "type": "string",
      "minLength": 1
    },
    "minutes": {
      "type": "integer",
      "minimum": 0
    },
    "record_id": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": false
}
