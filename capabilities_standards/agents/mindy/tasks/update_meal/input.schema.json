{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "update_meal.input",
  "type": "object",
  "required": ["meal_selector", "updates"],
  "properties": {
    "meal_selector": {
      "type": "object",
      "required": ["date", "time"],
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "time": { "type": "string", "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d)?$" },
        "meal_type": {
          "type": "string",
          "enum": ["desayuno", "comida", "cena", "snack", "pre-entreno", "other"]
        }
      },
      "additionalProperties": false
    },
    "updates": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "food_description": { "type": "string", "minLength": 1 },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "macro_estimated": { "type": "boolean" },
        "comments": { "type": "string" },
        "meal_type": {
          "type": "string",
          "enum": ["desayuno", "comida", "cena", "snack", "pre-entreno", "other"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
