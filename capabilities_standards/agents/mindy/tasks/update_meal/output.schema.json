{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "update_meal.output",
  "type": "object",
  "required": ["protocol_version", "task", "ok", "data", "error", "meta"],
  "properties": {
    "protocol_version": { "const": "1.0.0" },
    "task": { "const": "update_meal" },
    "ok": { "type": "boolean" },
    "data": {
      "type": ["object", "null"],
      "required": ["time_ref", "correction_applied", "changes"],
      "properties": {
        "time_ref": { "type": "string" },
        "correction_applied": { "type": "boolean" },
        "correction_note": { "type": "string" },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "old", "new"],
            "properties": {
              "field": { "type": "string", "enum": ["calories", "protein", "carbs", "fat", "fiber"] },
              "old": { "type": ["number", "string", "null"] },
              "new": { "type": ["number", "string", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "error": {
      "type": ["object", "null"],
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "VALIDATION_ERROR",
            "OUT_OF_SCOPE_TASK",
            "UNAUTHORIZED",
            "DB_CONNECTION_ERROR",
            "DB_QUERY_ERROR",
            "DB_CONFLICT",
            "NOT_FOUND",
            "INTERNAL_ERROR"
          ]
        },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "required": ["timestamp", "trace_id"],
      "properties": {
        "source": { "const": "duckdb" },
        "db_path": { "const": "/home/ubuntu/health_system.duckdb" },
        "agent_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "trace_id": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } }, "required": ["ok"] },
      "then": { "properties": { "data": { "type": "object" }, "error": { "type": "null" } } }
    },
    {
      "if": { "properties": { "ok": { "const": false } }, "required": ["ok"] },
      "then": {
        "properties": {
          "data": { "type": "null" },
          "error": { "type": "object", "required": ["code", "message"] }
        }
      }
    }
  ],
  "additionalProperties": false
}
