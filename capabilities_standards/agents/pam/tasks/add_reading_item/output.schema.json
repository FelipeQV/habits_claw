{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_reading_item.output",
  "type": "object",
  "required": ["protocol_version", "task", "ok", "data", "error", "meta"],
  "properties": {
    "protocol_version": { "const": "1.0.0" },
    "task": { "const": "add_reading_item" },
    "ok": { "type": "boolean" },
    "data": {
      "type": ["object", "null"],
      "required": ["reading_id", "url", "description", "status", "categories", "created_at"],
      "properties": {
        "reading_id": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "status": { "const": "unread" },
        "categories": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "source": { "type": ["string", "null"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "error": {
      "type": ["object", "null"],
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "VALIDATION_ERROR",
            "OUT_OF_SCOPE_TASK",
            "UNAUTHORIZED",
            "DB_CONNECTION_ERROR",
            "DB_QUERY_ERROR",
            "DB_CONFLICT",
            "NOT_FOUND",
            "INTERNAL_ERROR"
          ]
        },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "required": ["source", "db_path", "timestamp", "trace_id", "agent_id"],
      "properties": {
        "source": { "const": "duckdb" },
        "db_path": { "const": "/home/ubuntu/health_system.duckdb" },
        "timestamp": { "type": "string", "format": "date-time" },
        "trace_id": { "type": "string" },
        "agent_id": { "const": "pam" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {"if": {"properties": {"ok": {"const": true}}}, "then": {"properties": {"data": {"type": "object"}, "error": {"type": "null"}}}},
    {"if": {"properties": {"ok": {"const": false}}}, "then": {"properties": {"error": {"type": "object"}}}}
  ],
  "additionalProperties": false
}
