{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "list_focus_queue.output",
  "type": "object",
  "required": ["protocol_version", "task", "ok", "data", "error", "meta"],
  "properties": {
    "protocol_version": { "const": "1.0.0" },
    "task": { "const": "list_focus_queue" },
    "ok": { "type": "boolean" },
    "data": {
  "type": ["object", "null"],
  "required": ["count", "items", "unread_count", "data_quality"],
  "properties": {
    "count": {"type": "integer", "minimum": 0},
    "unread_count": {"type": "integer", "minimum": 0},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["todo_id", "title", "status"],
        "properties": {
          "todo_id": {"type": "string"},
          "title": {"type": "string"},
          "status": {"type": "string", "enum": ["active", "deferred"]},
          "priority_label": {"type": ["string", "null"]},
          "priority_rank": {"type": ["integer", "null"]},
          "due_date": {"type": ["string", "null"], "pattern": "^\\\\d{4}-\\\\d{2}-\\\\d{2}$"},
          "updated_at": {"type": ["string", "null"], "format": "date-time"},
          "due_soon": {"type": "integer", "enum": [0, 1]}
        },
        "additionalProperties": false
      }
    },
    "data_quality": {
      "type": "object",
      "required": ["level", "reason"],
      "properties": {"level": {"enum": ["low", "mid", "high"]}, "reason": {"type": "string"}},
      "additionalProperties": false
    }
  },
  "additionalProperties": false
},
    "error": {
      "type": ["object", "null"],
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "VALIDATION_ERROR",
            "OUT_OF_SCOPE_TASK",
            "UNAUTHORIZED",
            "DB_CONNECTION_ERROR",
            "DB_QUERY_ERROR",
            "DB_CONFLICT",
            "NOT_FOUND",
            "INTERNAL_ERROR"
          ]
        },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "required": ["source", "db_path", "timestamp", "trace_id", "agent_id"],
      "properties": {
        "source": { "const": "duckdb" },
        "db_path": { "const": "/home/ubuntu/health_system.duckdb" },
        "timestamp": { "type": "string", "format": "date-time" },
        "trace_id": { "type": "string" },
        "agent_id": { "const": "pam" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {"if": {"properties": {"ok": {"const": true}}}, "then": {"properties": {"data": {"type": "object"}, "error": {"type": "null"}}}},
    {"if": {"properties": {"ok": {"const": false}}}, "then": {"properties": {"error": {"type": "object"}}}}
  ],
  "additionalProperties": false
}
