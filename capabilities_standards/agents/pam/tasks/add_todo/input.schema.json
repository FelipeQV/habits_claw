{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_todo.input",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "priority_label": { "type": "string", "minLength": 1 },
    "priority_rank": { "type": "integer", "minimum": 1, "maximum": 999 },
    "due_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
