{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "prioritize_todos.input",
  "type": "object",
  "required": ["todo_id"],
  "properties": {
    "todo_id": { "type": "string", "minLength": 1 },
    "priority_label": { "type": "string", "minLength": 1 },
    "priority_rank": { "type": "integer", "minimum": 1, "maximum": 999 }
  },
  "anyOf": [
    { "required": ["priority_label"] },
    { "required": ["priority_rank"] }
  ],
  "additionalProperties": false
}
